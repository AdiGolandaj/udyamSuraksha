# DisasterShield Backend Environment Variables

# FastAPI
ENVIRONMENT=development
DEBUG=true
API_PORT=8000
API_HOST=0.0.0.0

# Database (MySQL)
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/disaster_shield
# Format: mysql+pymysql://user:password@host:port/database

# LLM & AI Integration
# Google Generative AI (Gemini)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL_NAME=gemini-1.5-pro

# OpenAI (Alternative)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4-turbo

# LLM Provider Selection (google or openai)
LLM_PROVIDER=google

# External APIs
# Meteosource Weather API
METEOSOURCE_API_KEY=your_meteosource_api_key_here

# Nominatim (OpenStreetMap) — No key required, but user-agent recommended
NOMINATIM_USER_AGENT=DisasterShield/1.0

# Open-Elevation — No key required
OPEN_ELEVATION_URL=https://api.open-elevation.com

# OpenTopoData — No key required
OPENTOPODATA_URL=https://api.opentopodata.org

# Overpass API — No key required
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# APScheduler Configuration
SCHEDULER_TIMEZONE=Asia/Kolkata
ALERT_BATCH_INTERVAL_HOURS=1
LOCATION_REFRESH_INTERVAL_DAYS=30

# API Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Session & Security
API_KEY_SECRET=your_api_key_secret_here

# Mail Notifications (Optional for Phase 2)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@disastershield.com
